{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores additional user information like UG number and custom profile details.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL."
        },
        "ugNumber": {
          "type": "string",
          "description": "The user's Undergraduate (UG) number."
        },
        "bio": {
          "type": "string",
          "description": "A short biography about the user."
        },
        "lastSeen": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the user was active in the app."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the profile was updated."
        }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Todo": {
      "title": "To-do Item",
      "description": "A task for a specific user on a specific date.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "description": "Date in YYYY-MM-DD format" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "text", "completed"]
    },
    "LearningMaterial": {
      "title": "Learning Material",
      "description": "A study resource for a specific course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "study-guide", "video", "link"] },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "addedBy": { "type": "string" }
      },
      "required": ["courseId", "title", "type", "url", "addedBy"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat conversation between users or a course group",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the chat." },
        "name": { "type": "string", "description": "The name of the chat or course." },
        "type": { "type": "string", "enum": ["direct", "course", "group"], "description": "The type of chat." },
        "participants": { "type": "array", "items": { "type": "string" }, "description": "List of user UIDs in the chat." },
        "lastMessage": { "type": "string", "description": "The content of the last message sent." },
        "lastActive": { "type": "string", "format": "date-time", "description": "Timestamp of the last activity." },
        "avatar": { "type": "string", "description": "URL of the chat avatar (for direct chats)." },
        "color": { "type": "string", "description": "Tailwind color class (for course chats)." },
        "code": { "type": "string", "description": "Course code (for course chats)." }
      },
      "required": ["type", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the message." },
        "chatId": { "type": "string", "description": "The ID of the parent chat." },
        "senderId": { "type": "string", "description": "The UID of the sender." },
        "senderName": { "type": "string", "description": "The display name of the sender." },
        "senderAvatar": { "type": "string", "description": "The photo URL of the sender." },
        "content": { "type": "string", "description": "The text content of the message." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." },
        "type": { "type": "string", "enum": ["text", "image", "file"], "description": "The type of message content." },
        "fileUrl": { "type": "string", "description": "URL of the attached file/image." },
        "fileName": { "type": "string", "description": "Original name of the attached file." }
      },
      "required": ["chatId", "senderId", "content", "timestamp"]
    },
    "ReviewDeck": {
      "title": "Review Deck",
      "description": "A collection of flashcards for a specific course and user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "courseId": { "type": "string" },
        "cardsCount": { "type": "number" },
        "lastReviewed": { "type": "string", "format": "date-time" },
        "progress": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "courseId", "cardsCount", "progress"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A single flashcard with a front and back side.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "deckId": { "type": "string" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["deckId", "front", "back"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/todos/{todoId}": {
      "schema": "Todo",
      "description": "Collection of to-do items for all users."
    },
    "/materials/{materialId}": {
      "schema": "LearningMaterial",
      "description": "Collection of all learning materials for all courses."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Collection of all chat conversations."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Subcollection of messages within a chat."
    },
    "/decks/{deckId}": {
      "schema": "ReviewDeck",
      "description": "Collection of all review decks."
    },
    "/decks/{deckId}/flashcards/{cardId}": {
      "schema": "Flashcard",
      "description": "Subcollection of flashcards within a deck."
    }
  }
}
