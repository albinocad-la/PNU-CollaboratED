{
  "entities": {
    "UserProfile": {
      "title": "User Profile",
      "description": "Stores additional user information like UG number and custom profile details.",
      "type": "object",
      "properties": {
        "uid": {
          "type": "string",
          "description": "The unique identifier for the user."
        },
        "displayName": {
          "type": "string",
          "description": "The user's display name."
        },
        "email": {
          "type": "string",
          "description": "The user's email address."
        },
        "photoURL": {
          "type": "string",
          "description": "The user's profile picture URL."
        },
        "ugNumber": {
          "type": "string",
          "description": "The user's Undergraduate (UG) number."
        },
        "bio": {
          "type": "string",
          "description": "A short biography about the user."
        },
        "lastSeen": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the user was active in the app."
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time",
          "description": "The last time the profile was updated."
        }
      },
      "required": ["uid", "displayName", "email"]
    },
    "Todo": {
      "title": "To-do Item",
      "description": "A task for a specific user on a specific date.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "date": { "type": "string", "description": "Date in YYYY-MM-DD format" },
        "text": { "type": "string" },
        "completed": { "type": "boolean" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "date", "text", "completed"]
    },
    "LearningMaterial": {
      "title": "Learning Material",
      "description": "A study resource for a specific course.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "courseId": { "type": "string" },
        "title": { "type": "string" },
        "type": { "type": "string", "enum": ["pdf", "study-guide", "video", "link"] },
        "url": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" },
        "addedBy": { "type": "string" }
      },
      "required": ["courseId", "title", "type", "url", "addedBy"]
    },
    "Chat": {
      "title": "Chat",
      "description": "A chat conversation between users or a course group",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the chat." },
        "name": { "type": "string", "description": "The name of the chat or course." },
        "type": { "type": "string", "enum": ["direct", "course", "group"], "description": "The type of chat." },
        "participants": { "type": "array", "items": { "type": "string" }, "description": "List of user UIDs in the chat." },
        "lastMessage": { "type": "string", "description": "The content of the last message sent." },
        "lastActive": { "type": "string", "format": "date-time", "description": "Timestamp of the last activity." },
        "avatar": { "type": "string", "description": "URL of the chat avatar (for direct chats)." },
        "color": { "type": "string", "description": "Tailwind color class (for course chats)." },
        "code": { "type": "string", "description": "Course code (for course chats)." },
        "participantsInfo": { "type": "object", "description": "Map of user UIDs to their display name and photo URL." },
        "nicknames": { "type": "object", "description": "Map of user UIDs to their custom nicknames in the chat." },
        "deletedBy": { "type": "array", "items": { "type": "string" }, "description": "List of user UIDs who have 'deleted' the chat from their view." }
      },
      "required": ["type", "participants"]
    },
    "Message": {
      "title": "Message",
      "description": "A message within a chat",
      "type": "object",
      "properties": {
        "id": { "type": "string", "description": "The unique identifier for the message." },
        "chatId": { "type": "string", "description": "The ID of the parent chat." },
        "senderId": { "type": "string", "description": "The UID of the sender." },
        "senderName": { "type": "string", "description": "The display name of the sender." },
        "senderAvatar": { "type": "string", "description": "The photo URL of the sender." },
        "content": { "type": "string", "description": "The text content of the message." },
        "timestamp": { "type": "string", "format": "date-time", "description": "When the message was sent." },
        "type": { "type": "string", "enum": ["text", "image", "file"], "description": "The type of message content." },
        "fileUrl": { "type": "string", "description": "URL of the attached file/image." },
        "fileName": { "type": "string", "description": "Original name of the attached file." },
        "isDeleted": { "type": "boolean", "description": "Whether the message has been 'unsent'." },
        "replyTo": { 
          "type": "object", 
          "properties": {
            "id": { "type": "string" },
            "senderName": { "type": "string" },
            "content": { "type": "string" }
          },
          "description": "Information about the message being replied to."
        }
      },
      "required": ["chatId", "senderId", "content", "timestamp"]
    },
    "ReviewDeck": {
      "title": "Review Deck",
      "description": "A collection of flashcards for a specific course and user.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "courseId": { "type": "string" },
        "cardsCount": { "type": "number" },
        "lastReviewed": { "type": "string", "format": "date-time" },
        "progress": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "courseId", "cardsCount", "progress"]
    },
    "Flashcard": {
      "title": "Flashcard",
      "description": "A single flashcard with a front and back side.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "deckId": { "type": "string" },
        "front": { "type": "string" },
        "back": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["deckId", "front", "back"]
    },
    "Friend": {
      "title": "Friend",
      "description": "A mutual friend relationship.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The UID of the friend." },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "Following": {
      "title": "Following",
      "description": "A user being followed.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The UID of the followed user." },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "Follower": {
      "title": "Follower",
      "description": "A user who is following this user.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The UID of the follower." },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "BlockedUser": {
      "title": "Blocked User",
      "description": "A user who has been blocked.",
      "type": "object",
      "properties": {
        "uid": { "type": "string", "description": "The UID of the blocked user." },
        "displayName": { "type": "string" },
        "photoURL": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "displayName", "createdAt"]
    },
    "StudySession": {
      "title": "Study Session",
      "description": "A record of a study session, including duration and cards reviewed.",
      "type": "object",
      "properties": {
        "id": { "type": "string" },
        "userId": { "type": "string" },
        "startTime": { "type": "string", "format": "date-time" },
        "endTime": { "type": "string", "format": "date-time" },
        "durationMinutes": { "type": "number" },
        "cardsReviewed": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "startTime", "endTime", "durationMinutes", "cardsReviewed"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": "UserProfile",
      "description": "Collection of user profiles."
    },
    "/users/{userId}/friends/{friendId}": {
      "schema": "Friend",
      "description": "Subcollection of friends for a user."
    },
    "/users/{userId}/following/{followedId}": {
      "schema": "Following",
      "description": "Subcollection of users being followed."
    },
    "/users/{userId}/followers/{followerId}": {
      "schema": "Follower",
      "description": "Subcollection of followers for a user."
    },
    "/users/{userId}/blocked/{blockedId}": {
      "schema": "BlockedUser",
      "description": "Subcollection of blocked users for a user."
    },
    "/users/{userId}/sessions/{sessionId}": {
      "schema": "StudySession",
      "description": "Subcollection of study sessions for a user."
    },
    "/todos/{todoId}": {
      "schema": "Todo",
      "description": "Collection of to-do items for all users."
    },
    "/materials/{materialId}": {
      "schema": "LearningMaterial",
      "description": "Collection of all learning materials for all courses."
    },
    "/chats/{chatId}": {
      "schema": "Chat",
      "description": "Collection of all chat conversations."
    },
    "/chats/{chatId}/messages/{messageId}": {
      "schema": "Message",
      "description": "Subcollection of messages within a chat."
    },
    "/decks/{deckId}": {
      "schema": "ReviewDeck",
      "description": "Collection of all review decks."
    },
    "/decks/{deckId}/flashcards/{cardId}": {
      "schema": "Flashcard",
      "description": "Subcollection of flashcards within a deck."
    }
  }
}
